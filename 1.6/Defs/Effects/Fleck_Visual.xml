				<_TexAScaleDivisorPerProgress>1.5</_TexAScaleDivisorPerProgress>
				<_brightnessMultiplier>.15</_brightnessMultiplier>
				<_noiseIntensity>10</_noiseIntensity>
				<_ageToNoiseRatio>2</_ageToNoiseRatio>
			</shaderParameters>
			<drawSize>6</drawSize>
		</graphicData>
